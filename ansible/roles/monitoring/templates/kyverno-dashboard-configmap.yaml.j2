apiVersion: v1
kind: ConfigMap
metadata:
  name: kyverno-dashboard
  namespace: monitoring
  labels:
    grafana_dashboard: "1"
data:
  kyverno-dashboard.json: |
{% raw %}
    {
      "title": "Kyverno",
      "uid": "kyverno",
      "schemaVersion": 38,
      "refresh": "30s",
      "panels": [
        {
          "id": 1,
          "title": "Total Policy Results",
          "type": "stat",
          "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
          "targets": [
            {
              "expr": "sum(policy_report_result)",
              "legendFormat": "Total"
            }
          ]
        },
        {
          "id": 2,
          "title": "Policy Results by Status",
          "type": "piechart",
          "gridPos": {"x": 6, "y": 0, "w": 6, "h": 8},
          "targets": [
            {
              "expr": "sum by (status) (policy_report_result)",
              "legendFormat": "{{ status }}"
            }
          ]
        },
        {
          "id": 3,
          "title": "FAIL Results Over Time",
          "type": "timeseries",
          "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
          "targets": [
            {
              "expr": "sum by (policy) (policy_report_result{status=\"fail\"})",
              "legendFormat": "{{ policy }}"
            }
          ]
        },
        {
          "id": 4,
          "title": "Admission Requests",
          "type": "timeseries",
          "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
          "targets": [
            {
              "expr": "rate(kyverno_admission_requests_total[5m])",
              "legendFormat": "{{ resource_kind }} - {{ resource_request_operation }}"
            }
          ]
        },
        {
          "id": 5,
          "title": "Policy Execution Latency (p99)",
          "type": "timeseries",
          "gridPos": {"x": 0, "y": 18, "w": 12, "h": 6},
          "targets": [
            {
              "expr": "histogram_quantile(0.99, sum(rate(kyverno_policy_execution_duration_seconds_bucket[5m])) by (le, policy_name))",
              "legendFormat": "{{ policy_name }}"
            }
          ]
        }
      ],
      "templating": {
        "list": [
          {
            "name": "namespace",
            "type": "query",
            "query": "label_values(policy_report_result, namespace)"
          }
        ]
      },
      "time": "now-6h",
      "timezone": "browser"
    }
{% endraw %}